{
    "name": "studuy-api",
    "version": "1.0.0",
    "main": "dist/server.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "nodemon --exec ts-node src/server.ts",
        "build": "tsc",
        "test": "jest",
        "test:security": "jest --runInBand tests/security",
        "test:coverage": "jest --coverage --runInBand",
        "test:smoke": "jest --runInBand tests/smoke",
        "test:livestream": "jest --runInBand tests/livestream/reliability/livestream.reliability.integration.test.ts tests/livestream/realtime/livestream.controls.integration.test.ts tests/livestream/realtime/livestream.presence.integration.test.ts tests/livestream/access/livestream.join.integration.test.ts tests/livestream/lifecycle/livestream.lifecycle.integration.test.ts"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1032.0",
        "@nestjs/common": "^11.1.19",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/mongoose": "^11.0.4",
        "bcrypt": "^6.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.1",
        "express-rate-limit": "^8.3.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.23.0",
        "nodemailer": "^8.0.2",
        "reflect-metadata": "^0.2.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "uit-authenticator": "^1.0.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^22.13.4",
        "@types/nodemailer": "^7.0.11",
        "@types/supertest": "^7.2.0",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "jest": "^30.3.0",
        "nodemon": "^3.1.7",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3"
    }
